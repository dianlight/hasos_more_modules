{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": ["dependencies"],
  "reviewers": [],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Dependency Dashboard",

  "packageRules": [
    {
      "description": "Group all updates together for simplicity",
      "matchPackagePatterns": ["*"],
      "groupName": "all dependencies"
    }
  ],

  "customManagers": [
    {
      "description": "Track OpenZFS ref in config/modules.json",
      "customType": "regex",
      "fileMatch": ["^config/modules\\.json$"],
      "matchStrings": [
        "\"repo\":\\s*\"https://github\\.com/openzfs/zfs\",\\s*\"ref\":\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "openzfs/zfs",
      "versioningTemplate": "loose"
    },
    {
      "description": "Track lxin/quic ref in config/modules.json",
      "customType": "regex",
      "fileMatch": ["^config/modules\\.json$"],
      "matchStrings": [
        "\"repo\":\\s*\"https://github\\.com/lxin/quic\",\\s*\"ref\":\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "lxin/quic",
      "versioningTemplate": "loose"
    }
  ],

  "ignorePaths": [
    "**/node_modules/**",
    "**/vendor/**"
  ]
}
